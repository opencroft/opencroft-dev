{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev server (Vite)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev"
    },
    {
      "name": "Debug client (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:9999"
    },
    {
      "name": "Dev full stack (Vite + Chrome)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "env": {
        "NO_COLOR": "1"
      },
      "serverReadyAction": {
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}"
      }
    },
    {
      "name": "Prod server (dist/prod.mjs)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/prod.mjs",
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    }
  ]
}
