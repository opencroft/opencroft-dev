{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --port 3333"
    },
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3333"
    },
    {
      "name": "Next.js: debug full stack",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": [
        "--turbopack",
        "-H",
        "0.0.0.0",
        "--port",
        "3333"
      ],
      "runtimeArgs": [
        "--inspect"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}"
      }
    },
    {
      "name": "WebSocket: terminal",
      "type": "node-terminal",
      "request": "launch",
      "command": "npx tsx websocket/terminal.ts",
      "autoAttachChildProcesses": false
    }
  ],
  "compounds": [
    {
      "name": "Full Stack + WebSocket",
      "configurations": [
        "Next.js: debug full stack",
        "WebSocket: terminal"
      ],
      "stopAll": true
    }
  ]
}