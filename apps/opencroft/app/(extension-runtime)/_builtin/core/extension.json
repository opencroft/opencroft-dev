{
  "id": "builtin/core",
  "name": "Core",
  "version": "1.2.0",
  "description": "Core node catalog — infrastructure + storage + windows + scripts + api routes",
  "nodes": [
    {
      "typeId": "localhost",
      "name": "Localhost",
      "category": "Infrastructure",
      "icon": "Monitor",
      "handles": [
        { "id": "terminal", "contextType": "terminal-context", "role": "source", "label": "Terminal" },
        { "id": "fs-out", "contextType": "filesystem-target", "role": "source", "label": "Files" }
      ]
    },
    {
      "typeId": "wsl",
      "name": "WSL",
      "category": "Infrastructure",
      "icon": "SquareTerminal",
      "handles": [
        { "id": "terminal", "contextType": "terminal-context", "role": "source", "label": "Terminal" },
        { "id": "fs-out", "contextType": "filesystem-target", "role": "source", "label": "Files" }
      ]
    },
    {
      "typeId": "server",
      "name": "Server",
      "category": "Infrastructure",
      "icon": "Server",
      "handles": [
        { "id": "terminal", "contextType": "terminal-context", "role": "source", "label": "Terminal" },
        { "id": "fs-out", "contextType": "filesystem-target", "role": "source", "label": "Files" }
      ],
      "actions": [
        {
          "id": "setKey",
          "label": "Set SSH Key",
          "icon": "KeyRound",
          "description": "Assign a Key Store key to this server (key reference is \"<keyStoreNodeId>:<keyName>\"). With install=true, also append the key's public half to the remote's authorized_keys using the server's current credentials.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "description": "Key reference: \"<keyStoreNodeId>:<keyName>\"" },
              "install": {
                "type": "boolean",
                "description": "Also install the public key on the remote's authorized_keys (default: false)"
              }
            },
            "required": ["key"]
          }
        },
        {
          "id": "acceptHostKey",
          "label": "Accept Host Key",
          "icon": "ShieldCheck",
          "description": "Scan the remote host key and pin it into known_hosts so OpenSSH-based transports (e.g. docker over ssh://) stop failing host-key verification.",
          "inputSchema": { "type": "object", "properties": {} }
        }
      ]
    },
    {
      "typeId": "core-key-store",
      "name": "Key Store",
      "category": "Storage",
      "icon": "KeyRound",
      "actions": [
        {
          "id": "generate",
          "label": "Generate Key",
          "icon": "Plus",
          "description": "Generate a new SSH keypair in this Key Store. Returns the key name and type — never private key material.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Name for the new key" },
              "keyType": {
                "type": "string",
                "enum": ["ed25519", "rsa", "ecdsa"],
                "description": "Key algorithm (default: ed25519)"
              }
            },
            "required": ["name"]
          }
        },
        {
          "id": "list",
          "label": "List Keys",
          "icon": "List",
          "description": "List keys in this store with their type and fingerprint. Does not expose private key material.",
          "inputSchema": { "type": "object", "properties": {} }
        },
        {
          "id": "delete",
          "label": "Delete Key",
          "icon": "Trash2",
          "description": "Delete a key (and its public key) from this store.",
          "inputSchema": {
            "type": "object",
            "properties": { "name": { "type": "string", "description": "Name of the key to delete" } },
            "required": ["name"]
          }
        }
      ]
    },
    { "typeId": "core-secrets-store", "name": "Secrets Store", "category": "Storage", "icon": "ShieldCheck" },
    {
      "typeId": "terminal",
      "name": "Terminal Window",
      "category": "Windows",
      "icon": "TerminalSquare",
      "handles": [{ "id": "ssh-in", "contextType": "terminal-context", "role": "target", "label": "Terminal" }]
    },
    {
      "typeId": "file-manager",
      "name": "File Manager Window",
      "category": "Windows",
      "icon": "FolderOpen",
      "handles": [{ "id": "fs-in", "contextType": "filesystem-target", "role": "target", "label": "Files" }]
    },
    {
      "typeId": "script-bash",
      "name": "Bash Script",
      "category": "Scripts",
      "icon": "TerminalSquare",
      "handles": [
        { "id": "ctx-in", "contextType": "terminal-context", "role": "target", "label": "Target" },
        { "id": "stdout-out", "contextType": "text-stream", "role": "source", "label": "Output" }
      ],
      "actions": [
        {
          "id": "run",
          "label": "Run",
          "icon": "Play",
          "description": "Execute the script in the connected terminal context (or local if none)."
        }
      ]
    },
    {
      "typeId": "script-python",
      "name": "Python Script",
      "category": "Scripts",
      "icon": "Code",
      "handles": [
        { "id": "ctx-in", "contextType": "terminal-context", "role": "target", "label": "Target" },
        { "id": "exec-in", "contextType": "execution-context", "role": "target", "label": "Handler" },
        { "id": "stdout-out", "contextType": "text-stream", "role": "source", "label": "Output" }
      ],
      "actions": [
        {
          "id": "run",
          "label": "Run",
          "icon": "Play",
          "description": "Execute the script in the connected terminal context (or local if none)."
        }
      ]
    },
    {
      "typeId": "script-node",
      "name": "Node.js Script",
      "category": "Scripts",
      "icon": "Braces",
      "handles": [
        { "id": "ctx-in", "contextType": "terminal-context", "role": "target", "label": "Target" },
        { "id": "exec-in", "contextType": "execution-context", "role": "target", "label": "Handler" },
        { "id": "stdout-out", "contextType": "text-stream", "role": "source", "label": "Output" }
      ],
      "actions": [
        {
          "id": "run",
          "label": "Run",
          "icon": "Play",
          "description": "Execute the script in the connected terminal context (or local if none)."
        }
      ]
    },
    {
      "typeId": "network",
      "name": "Network",
      "category": "Applications",
      "icon": "Network"
    },
    {
      "typeId": "send-message",
      "name": "Send Message",
      "category": "Integration",
      "icon": "Send",
      "handles": [{ "id": "text-in", "contextType": "text-stream", "role": "target", "label": "Text" }]
    },
    {
      "typeId": "api-route",
      "name": "API Route",
      "category": "Integration",
      "icon": "Route",
      "handles": [{ "id": "exec-out", "contextType": "execution-context", "role": "source", "label": "Handler" }]
    },
    {
      "typeId": "event",
      "name": "Event",
      "category": "Integration",
      "icon": "AlarmClock",
      "handles": [{ "id": "exec-out", "contextType": "execution-context", "role": "source", "label": "Handler" }],
      "actions": [
        { "id": "run", "label": "Run", "icon": "Play", "description": "Fire the connected handler immediately." }
      ]
    },
    {
      "typeId": "prompt",
      "name": "Prompt",
      "category": "Text",
      "icon": "MessageCircle",
      "handles": [{ "id": "text-out", "contextType": "text-stream", "role": "source", "label": "Text" }]
    },
    {
      "typeId": "text-generation",
      "name": "Text Generation",
      "category": "Text",
      "icon": "Sparkles",
      "handles": [
        { "id": "text-in", "contextType": "text-stream", "role": "target", "label": "Prompt", "streamAction": "run" },
        { "id": "text-out", "contextType": "text-stream", "role": "source", "label": "Text" }
      ]
    },
    { "typeId": "section", "name": "Section", "category": "Organization", "icon": "Boxes" },
    { "typeId": "domain", "name": "Domain", "category": "Organization", "icon": "Globe" }
  ],
  "contexts": [
    {
      "id": "terminal-context",
      "label": "Terminal Context",
      "color": "oklch(0.7 0.18 300)",
      "description": "Terminal execution context (local, WSL, or SSH)"
    },
    { "id": "filesystem-target", "label": "Filesystem Target", "color": "oklch(0.7 0.17 140)" },
    {
      "id": "execution-context",
      "label": "Execution Context",
      "color": "oklch(0.72 0.17 30)",
      "description": "Async execution context for request/response handlers"
    }
  ]
}
